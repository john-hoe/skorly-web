# ============================================================
# Skorly environment variables
# Copy to .env (gitignored) and fill values.
# Real keys live in /Users/johnmacmini/workspace/.env/apikey
# ============================================================

# --- Database (Supabase Postgres) ---
# Use the CONNECTION POOLER string (Supavisor, transaction mode, port 6543)
# from Supabase dashboard: Project Settings -> Database -> Connection string -> "Transaction"
# Confirmed for this project (ref majrlaxktengachwrskk, region ap-northeast-2, pooler host prefix aws-1):
# DATABASE_URL="postgresql://postgres.majrlaxktengachwrskk:URL_ENCODED_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres"
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres"
# Supabase project URL + keys (Supabase Auth: register/login/OAuth/email verify/reset)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Public (browser) Supabase Auth client — same URL + anon key, exposed to the client
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- Cloudflare Turnstile (anti-abuse on register + subscribe) ---
# Dashboard: Cloudflare -> Turnstile -> add site (skorly.cc). Site key is public.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Cache (Upstash Redis, REST) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Sports data (API-Football) ---
API_FOOTBALL_KEY=""
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"

# --- LLM providers (already available in ~/.env/apikey) ---
# Generation (primary)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# Judge + fallback router (access GPT/Gemini/Claude/etc via one key)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_JUDGE_MODEL="google/gemini-2.0-flash-001"

# SEA-language fallback (Qwen via Alibaba DashScope / Bailian)
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"

# SEA-language second fallback (Zhipu GLM)
GLM_API_KEY=""
GLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
GLM_MODEL="glm-4-plus"

# --- Email (Resend) ---
RESEND_API_KEY=""
RESEND_FROM="Skorly <noreply@skorly.cc>"

# --- Cloudflare (Pages / Workers / R2) ---
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
R2_BUCKET="skorly-assets"
R2_PUBLIC_BASE_URL=""

# --- Admin jobs bridge ---
# JOBS_ADMIN_SECRET must be set as a secret on both web and jobs Workers.
# JOBS_ADMIN_URL is server-only and points web admin actions at the jobs Worker.
JOBS_ADMIN_SECRET=""
JOBS_ADMIN_URL="https://skorly-jobs.YOUR_SUBDOMAIN.workers.dev"

# --- Site config ---
NEXT_PUBLIC_SITE_URL="https://skorly.cc"
NEXT_PUBLIC_DEFAULT_LOCALE="id"
NEWS_ARTICLE_AUTHOR_NAME="John Vega"
# Optional. Defaults to the localized built-in author page.
# NEWS_ARTICLE_AUTHOR_URL="https://skorly.cc/en/author/john-vega"

# --- Monitoring (optional) ---
SENTRY_DSN=""
NEXT_PUBLIC_GA_ID=""
GA4_API_SECRET=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Web Push (PWA notifications, M3) ---
# Generate with: node -e "..."(ECDSA P-256). Public key is exposed to the browser.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:business@skorly.cc

# --- WhatsApp Business Cloud API (M7, optional) ---
# Premium-plan broadcast also fans out to WhatsApp when these are set.
# Token is a secret; phone id + template are Meta Business identifiers.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TEMPLATE=premium_prediction
WHATSAPP_API_VERSION=v21.0
