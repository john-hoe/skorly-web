{
  "name": "skorly",
  "version": "0.1.0",
  "private": true,
  "description": "Skorly - football news site for Indonesia/Vietnam/Philippines (WC2026)",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @skorly/web dev",
    "build": "pnpm --filter @skorly/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @skorly/db generate",
    "db:push": "pnpm --filter @skorly/db push",
    "db:studio": "pnpm --filter @skorly/db studio"
  },
  "devDependencies": {
    "tsx": "^4.22.3"
  }
}
